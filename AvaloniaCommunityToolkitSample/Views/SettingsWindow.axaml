<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaCommunityToolkitSample.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="220"
        x:Class="AvaloniaCommunityToolkitSample.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="设置"
        Width="420" Height="220"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="主题" FontWeight="SemiBold"/>

        <ComboBox ItemsSource="{Binding ThemeOptions}"
                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                  HorizontalAlignment="Left"
                  MinWidth="180"/>

        <TextBlock Text="提示：主题切换会立即生效" Opacity="0.7" Margin="0,4,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,16,0,0">
            <Button Content="取消" Command="{Binding CancelCommand}"/>
            <Button Content="应用" Command="{Binding ApplyCommand}" Classes="accent"/>
        </StackPanel>
    </StackPanel>
</Window>

